rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Creators — global creator identity
    match /creators/{creatorId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    // Shared forms
    match /shared_forms/{formId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    // Magic links
    match /magic_links/{token} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    // Shared responses
    match /shared_responses/{responseId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    // Collaborators
    match /collaborators/{collabId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    // Invite codes
    match /invite_codes/{code} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    // Audit logs
    match /audit_logs/{logId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    // Shared plugins
    match /shared_plugins/{pluginId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }
  }
}
